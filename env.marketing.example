# Marketing area – copy to .env and fill

# Required
JWT_SECRET=your-secret-min-32-chars
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxx
RESEND_SENDER_EMAIL=marketing@yourdomain.com

# Optional
MARKETING_JWT_TTL_MINUTES=15
MARKETING_REFRESH_TTL_DAYS=7
MARKETING_BACKFILL_FROM_SITE=true
# Seed opcional (nunca commite valores reais). JSON em uma linha; use aspas simples externas no .env.
# Ex.: MARKETING_SEED_USERS_JSON='[{"email":"dev@example.com","password":"só-local","name":"Dev"}]'
# MARKETING_SEED_ON_STARTUP=true

# Optional – lead sync
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# HUBSPOT_ACCESS_TOKEN=
