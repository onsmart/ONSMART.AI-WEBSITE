# Marketing area – copy to .env and fill

# Required
JWT_SECRET=your-secret-min-32-chars
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxx
RESEND_SENDER_EMAIL=marketing@yourdomain.com

# Optional
MARKETING_JWT_TTL_MINUTES=15
MARKETING_REFRESH_TTL_DAYS=7
MARKETING_BACKFILL_FROM_SITE=true
# Rodar seed do usuário de marketing ao subir o server (útil com npm run dev:full)
MARKETING_SEED_ON_STARTUP=true
MARKETING_SEED_EMAIL=marketing@onsmart.com.br
MARKETING_SEED_PASSWORD=senha123

# Optional – lead sync
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# HUBSPOT_ACCESS_TOKEN=
