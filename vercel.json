{
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/trpc/[...trpc].js": {
      "maxDuration": 15
    },
    "api/trpc/index.js": {
      "maxDuration": 15
    },
    "api/elevenlabs-widget.js": {
      "maxDuration": 10
    },
    "api/elevenlabs/webhook.js": {
      "maxDuration": 30
    },
    "api/calendly-polling.js": {
      "maxDuration": 30
    },
    "api/whatsapp/webhook.js": {
      "maxDuration": 30
    },
    "api/whatsapp/webhook/connection-update.js": {
      "maxDuration": 10
    }
  }
}