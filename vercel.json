{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/trpc",
      "destination": "/api/trpc/_"
    },
    {
      "source": "/health",
      "destination": "/api/trpc/__health"
    },
    {
      "source": "/api/health",
      "destination": "/api/trpc/__health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/trpc/[...trpc].js": {
      "maxDuration": 15
    },
    "api/elevenlabs-widget.js": {
      "maxDuration": 10
    },
    "api/elevenlabs/webhook.js": {
      "maxDuration": 30
    },
    "api/calendly-polling.js": {
      "maxDuration": 30
    },
    "api/whatsapp/webhook.js": {
      "maxDuration": 30
    },
    "api/whatsapp/webhook/connection-update.js": {
      "maxDuration": 10
    },
    "api/openai-format-html.js": {
      "maxDuration": 60
    }
  }
}